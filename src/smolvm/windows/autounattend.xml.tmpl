<?xml version="1.0" encoding="utf-8"?>
<!--
  SmolVM Windows unattended install answer file.
  Generated by smolvm.windows.build_image.render_autounattend.

  Placeholders (substituted via str.replace, NOT str.format, so brace
  characters in PowerShell commands below don't need escaping):

    @@SMOLVM_USERNAME@@ : local admin account name
    @@SMOLVM_PASSWORD@@ : local admin account password (plaintext in the
                          answer file; the answer-file ISO is short-lived
                          and discarded after the install)
    @@SMOLVM_HOSTNAME@@ : Windows computer name
    @@SMOLVM_EDITION@@  : edition name as it appears in install.wim
                          (default "Windows 11 Pro"; "Windows 11 Home"
                          and "Windows 11 Enterprise" also valid)

  Drives Windows Setup end-to-end with zero clicks:
    - windowsPE:    region/keyboard, accept EULA, preload virtio-scsi +
                    NetKVM drivers from the virtio-win CD, pick the
                    edition by name, wipe disk 0 and lay down ESP + MSR
                    + Windows partitions.
    - specialize:   computer name, UTC timezone, skip MS network
                    registration.
    - oobeSystem:   hide every OOBE pane, create local admin account,
                    enable auto-logon so FirstLogonCommands can run.
    - FirstLogon:   install virtio-win-guest-tools, install OpenSSH
                    from the GitHub release zip (not Windows Update),
                    drop a marker file at C:\smolvm-ready.txt the host
                    can probe via SSH to know the install finished.
-->
<unattend xmlns="urn:schemas-microsoft-com:unattend">

  <!-- ====================================================================
       Pass 1: windowsPE
       Runs inside Windows PE (the install environment). Loads virtio
       drivers, picks the edition, partitions the disk, accepts EULA.
       ==================================================================== -->
  <settings pass="windowsPE">

    <component name="Microsoft-Windows-International-Core-WinPE"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <SetupUILanguage>
        <UILanguage>en-US</UILanguage>
      </SetupUILanguage>
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

      <!-- Pre-inject virtio-scsi and virtio-net drivers so Setup can see
           the virtio-scsi disk and the virtio NIC. virtio-win CD typically
           mounts as E:\ during PE but drive letters depend on attach
           order; we list D:/E:/F: to cover the common arrangements. -->
      <DriverPaths>
        <PathAndCredentials wcm:action="add" wcm:keyValue="1">
          <Path>E:\vioscsi\w11\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="2">
          <Path>E:\NetKVM\w11\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="3">
          <Path>E:\viostor\w11\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="4">
          <Path>D:\vioscsi\w11\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="5">
          <Path>D:\NetKVM\w11\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="6">
          <Path>D:\viostor\w11\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="7">
          <Path>F:\vioscsi\w11\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="8">
          <Path>F:\NetKVM\w11\amd64</Path>
        </PathAndCredentials>
      </DriverPaths>

      <DiskConfiguration>
        <Disk wcm:action="add">
          <DiskID>0</DiskID>
          <WillWipeDisk>true</WillWipeDisk>
          <CreatePartitions>
            <CreatePartition wcm:action="add">
              <Order>1</Order>
              <Type>EFI</Type>
              <Size>260</Size>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>2</Order>
              <Type>MSR</Type>
              <Size>16</Size>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>3</Order>
              <Type>Primary</Type>
              <Extend>true</Extend>
            </CreatePartition>
          </CreatePartitions>
          <ModifyPartitions>
            <ModifyPartition wcm:action="add">
              <Order>1</Order>
              <PartitionID>1</PartitionID>
              <Label>System</Label>
              <Format>FAT32</Format>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>2</Order>
              <PartitionID>2</PartitionID>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>3</Order>
              <PartitionID>3</PartitionID>
              <Label>Windows</Label>
              <Letter>C</Letter>
              <Format>NTFS</Format>
            </ModifyPartition>
          </ModifyPartitions>
        </Disk>
        <WillShowUI>OnError</WillShowUI>
      </DiskConfiguration>

      <ImageInstall>
        <OSImage>
          <InstallFrom>
            <MetaData wcm:action="add">
              <Key>/IMAGE/NAME</Key>
              <Value>@@SMOLVM_EDITION@@</Value>
            </MetaData>
          </InstallFrom>
          <InstallTo>
            <DiskID>0</DiskID>
            <PartitionID>3</PartitionID>
          </InstallTo>
          <WillShowUI>OnError</WillShowUI>
          <InstallToAvailablePartition>false</InstallToAvailablePartition>
        </OSImage>
      </ImageInstall>

      <UserData>
        <AcceptEula>true</AcceptEula>
        <FullName>@@SMOLVM_USERNAME@@</FullName>
        <Organization>SmolVM</Organization>
      </UserData>
    </component>
  </settings>

  <!-- ====================================================================
       Pass 2: specialize
       ==================================================================== -->
  <settings pass="specialize">
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <ComputerName>@@SMOLVM_HOSTNAME@@</ComputerName>
      <TimeZone>UTC</TimeZone>
      <RegisteredOwner>@@SMOLVM_USERNAME@@</RegisteredOwner>
      <RegisteredOrganization>SmolVM</RegisteredOrganization>
    </component>
    <component name="Microsoft-Windows-Deployment"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <RunSynchronous>
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Path>reg add "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\OOBE" /v DisablePrivacyExperience /t REG_DWORD /d 1 /f</Path>
          <Description>Suppress OOBE privacy experience.</Description>
        </RunSynchronousCommand>
      </RunSynchronous>
    </component>
  </settings>

  <!-- ====================================================================
       Pass 3: oobeSystem
       ==================================================================== -->
  <settings pass="oobeSystem">
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideOEMRegistrationScreen>true</HideOEMRegistrationScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <ProtectYourPC>3</ProtectYourPC>
        <NetworkLocation>Work</NetworkLocation>
        <SkipMachineOOBE>true</SkipMachineOOBE>
        <SkipUserOOBE>true</SkipUserOOBE>
      </OOBE>

      <UserAccounts>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Name>@@SMOLVM_USERNAME@@</Name>
            <DisplayName>@@SMOLVM_USERNAME@@</DisplayName>
            <Group>Administrators</Group>
            <Password>
              <Value>@@SMOLVM_PASSWORD@@</Value>
              <PlainText>true</PlainText>
            </Password>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>

      <AutoLogon>
        <Username>@@SMOLVM_USERNAME@@</Username>
        <Enabled>true</Enabled>
        <LogonCount>1</LogonCount>
        <Password>
          <Value>@@SMOLVM_PASSWORD@@</Value>
          <PlainText>true</PlainText>
        </Password>
      </AutoLogon>

      <TimeZone>UTC</TimeZone>

      <FirstLogonCommands>
        <SynchronousCommand wcm:action="add">
          <Order>1</Order>
          <CommandLine>powershell -NoProfile -ExecutionPolicy Bypass -Command "foreach ($d in 'D','E','F','G','H') { $p = $d + ':\virtio-win-guest-tools.exe'; if (Test-Path $p) { Start-Process -FilePath $p -ArgumentList '/install','/quiet','/norestart' -Wait; break } }"</CommandLine>
          <Description>Install virtio-win-guest-tools silently from the virtio-win CD</Description>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>2</Order>
          <CommandLine>powershell -NoProfile -ExecutionPolicy Bypass -Command "$ProgressPreference='SilentlyContinue'; [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12; $url='https://github.com/PowerShell/Win32-OpenSSH/releases/download/v9.5.0.0p1-Beta/OpenSSH-Win64.zip'; $zip=$env:TEMP+'\OpenSSH.zip'; $expected='BD48FE985D400402C278C485DB20E6A82BC4C7F7D8E0EF5A81128F523096530C'; Invoke-WebRequest -Uri $url -OutFile $zip; $actual=(Get-FileHash -Path $zip -Algorithm SHA256).Hash; if ($actual -ne $expected) { Write-Error ('OpenSSH zip SHA256 mismatch: expected '+$expected+' got '+$actual); exit 1 }; Expand-Archive -Path $zip -DestinationPath 'C:\Program Files' -Force"</CommandLine>
          <Description>Download OpenSSH-Win64 v9.5.0.0p1-Beta, verify SHA256, unpack</Description>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>3</Order>
          <CommandLine>powershell -NoProfile -ExecutionPolicy Bypass -Command "&amp; 'C:\Program Files\OpenSSH-Win64\install-sshd.ps1'; Set-Service sshd -StartupType Automatic; Start-Service sshd; New-NetFirewallRule -Name sshd -DisplayName 'OpenSSH Server (sshd)' -Enabled True -Direction Inbound -Protocol TCP -Action Allow -LocalPort 22 -ErrorAction SilentlyContinue"</CommandLine>
          <Description>Register sshd service, start it, open TCP/22 firewall rule</Description>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>4</Order>
          <CommandLine>powershell -NoProfile -ExecutionPolicy Bypass -Command "Set-Content -Path C:\smolvm-ready.txt -Value (\"smolvm-win11 unattended install complete: \" + (Get-Date -Format 'o'))"</CommandLine>
          <Description>Write C:\smolvm-ready.txt marker for host-side completion probe</Description>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>
      </FirstLogonCommands>
    </component>
  </settings>

</unattend>
